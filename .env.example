# SonoBuddy Environment Variables
# Copy this file to .env.local for local development

# App URL (for OG tags, sitemap, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Future: Stripe for premium subscriptions
# STRIPE_SECRET_KEY=sk_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...

# Future: Auth (Clerk or NextAuth)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=...

# Future: Analytics
# NEXT_PUBLIC_POSTHOG_KEY=...

# Push Notifications (Web Push / VAPID)
# Generate keys with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@email.com

# Upstash Redis (stores push subscriptions — free tier at upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron secret — protects /api/push/send from unauthorized calls
# Generate with: openssl rand -hex 32
CRON_SECRET=
